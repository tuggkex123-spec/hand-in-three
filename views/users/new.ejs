<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', {title: "New user | Users"}) %>
<body>
  <%- include('../partials/header) %>

  <main>
    <h2>Create a new user</h2>

    <form action="/users" method="POST">
      <input type="text" name="user_name" placeholder="user_name" required /><br />
      <input type="text" name="slug" placeholder="slug" required /><br />
      <input type="number" name="age" placeholder="age" required min="0" step="1" /><br />
      <button>Save</button>
    </form>
  </main>

  
</body>
</html>