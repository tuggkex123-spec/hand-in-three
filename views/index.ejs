<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>User Manager</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h1>🌸 User Manager</h1>
    <p class="subtitle">Welcome back, bestie 💕</p>

    <div class="card">
      <p>There are currently <strong><%= userCount %></strong> users in the system.</p>
    </div>

    <nav>
      <a href="/users" class="btn">👯 View all users</a>
      <a href="/users/new" class="btn btn-pink">✨ Create a new user</a>
    </nav>
  </div>
</body>
</html>

